[Unit]
Description=MQTT Data Publisher
After=network-online.target timber-sensor-diameter.service timber-combine.service
Wants=network-online.target

[Service]
Type=simple
User=admin
WorkingDirectory=/path/to/timber-measurement-edge
ExecStart=/path/to/venv/bin/python3 scripts/diameter/mqtt_publisher.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
